# Clerk Authentication (Required)
# Get your keys from https://dashboard.clerk.com/last-active?path=api-keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY
CLERK_SECRET_KEY=YOUR_SECRET_KEY

# Logto Authentication (Required for authentication)
# Get your Logto configuration from your Logto instance
LOGTO_ENDPOINT=https://your-logto-instance.com
LOGTO_APP_ID=your_app_id
LOGTO_APP_SECRET=your_app_secret
LOGTO_COOKIE_SECRET=your_cookie_secret_at_least_32_characters_long
NEXT_PUBLIC_LOGTO_ENDPOINT=https://your-logto-instance.com
NEXT_PUBLIC_LOGTO_APP_ID=your_app_id

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_APP_URL=https://cloudgptapi.vercel.app

# AI Provider Keys (Optional but recommended for higher rate limits)
# Pollinations: https://enter.pollinations.ai
# You can configure multiple keys to distribute API costs and improve rate limits
POLLINATIONS_API_KEY=
POLLINATIONS_API_KEY_2=

# Routeway: https://api.routeway.ai
ROUTEWAY_API_KEY=your_routeway_api_key_here

# OpenRouter: https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# MapleAI: https://mapleai.de
MAPLEAI_API_KEY=

# AppyPie: https://gateway.appypie.com
APPYPIE_API_KEY=

# Stable Horde: https://stablehorde.net
STABLEHORDE_API_KEY=

# GitHub Models: https://github.com/marketplace/models
GITHUB_TOKEN=

# Meridian Labs (PolliStack Cognitive Substrate): https://meridianlabs.website
MERIDIAN_API_KEY=
