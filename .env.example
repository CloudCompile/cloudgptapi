# Kinde Authentication (Required)
# Get these from https://app.kinde.com/settings/applications
KINDE_CLIENT_ID=YOUR_CLIENT_ID
KINDE_CLIENT_SECRET=YOUR_CLIENT_SECRET
KINDE_AUTH_DOMAIN=https://YOUR_SUBDOMAIN.kinde.com
KINDE_REDIRECT_URI=http://localhost:3000/api/auth/callback
KINDE_LOGOUT_REDIRECT_URI=http://localhost:3000

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Replace with your actual deployed Vercel domain
NEXT_PUBLIC_APP_URL=https://vetraai.vercel.app

# AI Provider Keys (Optional but recommended for higher rate limits)
# Cloudflare AI Gateway (for routing OpenRouter + Pollinations chat through Cloudflare)
CF_AIG_TOKEN=
CF_AI_GATEWAY_CHAT_COMPLETIONS_URL=https://gateway.ai.cloudflare.com/v1/828393e6a7d75e508d1bf4a898bd1e6e/test/compat/chat/completions

# Pollinations: https://enter.pollinations.ai
POLLINATIONS_API_KEY=
POLLINATIONS_API_KEY_2=
KIVEST_API_KEY=
KIVEST_API_KEY_2=
# OpenRouter: https://openrouter.ai
# Supports OPENROUTER_API_KEY, OPENROUTER_FALLBACK_KEY, OR_KEY_1..N,
# OPENROUTER_API_KEY_1..N, and OPENROUTER_API_KEY1..N
OR_KEY=
OR_KEY_1=
OR_KEY_2=
OPENROUTER_API_KEY=
OPENROUTER_FALLBACK_KEY=
OPENROUTER_API_KEY_1=
OPENROUTER_API_KEY1=
OPENROUTER_API_KEY2=
OPENROUTER_API_KEY3=
OPENROUTER_API_KEY4=
OPENROUTER_API_KEY5=
OPENROUTER_API_KEY6=
OPENROUTER_API_KEY7=
OPENROUTER_API_KEY8=
OPENROUTER_API_KEY9=
OPENROUTER_API_KEY10=
# Shalom (Bluesminds): https://bluesminds.com
SHALOM_API_KEY=

# Optional remote Lorebook/Wiki plugin service URL
FANDOM_PLUGIN_URL=
